{
  "name": "modal-mcp-server",
  "version": "1.0.0",
  "description": "MCP server that lets AI agents run tests, training jobs, and Python GPU workloads on Modal.com",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "modal-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "doctor": "node dist/index.js doctor",
    "smoke:mcp": "node scripts/smoke-mcp.mjs",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "modal",
    "modal-com",
    "gpu",
    "ai",
    "testing",
    "training",
    "llm"
  ],
  "license": "MIT",
  "author": "AlphaTechLogics",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.0.0",
    "modal": "^0.7.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}